{
	"editor.fontSize": 12, // 字体大小
	"editor.defaultFormatter": "biomejs.biome", // 默认格式化器：所有文件（含 SVG）都用 Biome 格式化
	"editor.formatOnSave": true, // 保存时自动格式化：按 biome.jsonc 规则整理缩进/空格/引号等
	"editor.codeActionsOnSave": {
		// 保存时执行的代码操作（保存时自动触发）
		"source.fixAll.biome": "explicit", // 自动修复 lint 问题：let→const、==→===、删未用变量等
		"source.organizeImports.biome": "explicit" // 自动整理 import：按分组排序、合并重复引用
	},
	"code-runner.executorMap": {
		// 各语言运行命令（点右上角 ▶ 按钮时执行）
		"typescript": "npx tsx" // TypeScript 用 tsx 直接运行，不用先编译
	},
	"code-runner.runInTerminal": true, // 在终端里运行（能用 stdin，比输出面板更完整）
	"code-runner.saveFileBeforeRun": true, // 运行前先保存（确保跑的是最新代码）
	"code-runner.respectShebang": false, // 忽略文件顶部的 #!/usr/bin/env（统一用上面的 executorMap）
	"workbench.colorCustomizations": {
		"activityBar.background": "#1F2430", // Ayu Mirage 真实色值（带暖灰调）
		"activityBar.foreground": "#707A8C", // 雾灰蓝
		"activityBar.inactiveForeground": "#4E5666", // 暗灰
		"statusBar.background": "#242936", // 编辑区同色，整体感强
		"statusBar.foreground": "#959DAB", // 中灰
		"titleBar.activeBackground": "#1F2430", // 暖深黑
		"titleBar.activeForeground": "#959DAB", // 中灰
		"titleBar.inactiveBackground": "#141821", // 极深暖黑
		"titleBar.inactiveForeground": "#4E5666" // 暗灰
	},
	// "workbench.colorCustomizations": {
	// 	"activityBar.background": "#F5F3FF",
	// 	"activityBar.foreground": "#7C3AED",
	// 	"activityBar.inactiveForeground": "#C4B5FD",
	// 	"statusBar.background": "#FCE7F3",
	// 	"statusBar.foreground": "#9D174D",
	// 	"titleBar.activeBackground": "#FDF4FF", // ← 换成紫罗兰白
	// 	"titleBar.activeForeground": "#6B21A8",
	// 	"titleBar.inactiveBackground": "#F5F3FF",
	// 	"titleBar.inactiveForeground": "#C4B5FD"
	// },
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[prisma]": {
		"editor.defaultFormatter": "Prisma.prisma-insider"
	},
	// Markdown 用 dprint 格式化（Biome 不支持 md）；保存时自动触发
	"[markdown]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"biome.lsp.bin": "${workspaceFolder}/node_modules/@biomejs/biome/bin/biome"
}
