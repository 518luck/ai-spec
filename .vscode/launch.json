{
  // VSCode 调试配置
  "version": "0.2.0",
  "configurations": [
    {
      // 调试 Next.js 服务端：启动 pnpm dev:all 并 attach
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:all",
      "cwd": "${workspaceFolder}"
    },
    {
      // 调试当前打开的 TS 文件：用 tsx 跑，支持断点与 Debug Console 求值
      "name": "tsx: 调试当前文件",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "${file}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
