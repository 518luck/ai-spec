NEXT_PUBLIC_APP_NAME="AI Spec"

# Database
DATABASE_URL="postgresql://duoyun:postgres@localhost:5432/ai_spec?schema=public"

# Axiom logging
AXIOM_TOKEN=""
AXIOM_DATASET=""
IS_AXIOM_ENABLED=false

# Redis rate limiting
REDIS_URL="redis://localhost:6379"

# 邮件发送 provider：resend（生产，默认）| mailpit（本地开发捕获）
EMAIL_PROVIDER="resend"
# Resend email（EMAIL_PROVIDER=resend 时需要）
RESEND_API_KEY=""
# 本地 Mailpit SMTP（EMAIL_PROVIDER=mailpit 时生效）
SMTP_HOST="localhost"
SMTP_PORT="1026"

# S3 兼容对象存储（AWS S3 / Cloudflare R2 / MinIO）
# 自定义服务地址（R2 / MinIO 必填，AWS S3 留空）
S3_ENDPOINT=""
# 数据中心区域，默认 auto
S3_REGION="auto"
# 访问密钥 ID
S3_ACCESS_KEY_ID=""
# 访问密钥
S3_SECRET_ACCESS_KEY=""
# 公开存储桶名
S3_PUBLIC_BUCKET=""
# 私有存储桶名
S3_PRIVATE_BUCKET=""
# 公开访问基址，用于拼接文件 URL
S3_PUBLIC_URL=""

# NextAuth
AUTH_SECRET="change-me"
