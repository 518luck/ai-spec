// # 提示词域：收录主表（含版本/标签/收藏）+ 草稿暂存 + 可见性控制
//
// 收录(PromptRecord) 是正式归档内容，可属于个人或团队；草稿(PromptDraft) 仅个人暂存
// ! 收录与团队强绑定：团队/用户删除均级联删其收录

// 收录主表：承载完整内容、版本、标签与共享
model PromptRecord {
  // ① 主键
  id String @id @default(cuid()) // 收录主键

  // ② 业务字段
  name       String // 名称
  content    String     @db.Text // 提示词正文
  images     String[]   @default([]) // 图片 URL 列表，预留扩展
  visibility Visibility @default(private) // 可见性：private=私有，public=公开广场
  // 空间位置：null=个人空间（个人收录原件），非 null=团队空间（独立副本，与原件生命周期解耦）
  teamId     String?    @map("team_id")
  useCount   Int        @default(0) @map("use_count") // 使用次数，驱动"常用"排序

  // ③ 时间戳
  createdAt DateTime @default(now()) @map("created_at") // 创建时间
  updatedAt DateTime @updatedAt @map("updated_at") // 更新时间，驱动"最近"排序

  // ④ 外键列
  // 个人收录必有 owner；团队副本 owner 为 null（属于团队集体），用 contributedBy 标记贡献者
  ownerId       String? @map("owner_id")
  // 团队副本的贡献者 ID（复制动作的发起人）；个人收录为 null
  contributedBy String? @map("contributed_by")
  lastEditorId  String? @map("last_editor_id") // 最近编辑人 ID（团队协作场景）
  folderId      String? @map("folder_id") // 所属文件夹 ID，null=未分类

  // ⑤ 关联关系
  owner       User?                 @relation("PromptRecordOwner", fields: [ownerId], references: [id], onDelete: Cascade) // 创建者（删除用户→级联删除个人收录）
  // 贡献者（复制原件到团队的人）；贡献者注销→contributedBy 置空，副本保留
  contributor User?                 @relation("PromptRecordContributor", fields: [contributedBy], references: [id], onDelete: SetNull)
  lastEditor  User?                 @relation("PromptRecordEditor", fields: [lastEditorId], references: [id], onDelete: SetNull) // 最近编辑人（用户注销→仅清空记录）
  folder      Folder?               @relation("FolderItems_PromptRecord", fields: [folderId], references: [id], onDelete: SetNull) // 所属文件夹（文件夹删除→资源保留，folderId 置空）
  team        Team?                 @relation("TeamPromptRecords", fields: [teamId], references: [id], onDelete: Cascade) // 所属团队（团队删除→级联删除其空间内的收录；null=个人空间）
  versions    PromptRecordVersion[] // 版本历史
  tags        PromptRecordTag[] // 标签关联
  favoritedBy PromptFavorite[] // 收藏记录

  // ⑥ 索引
  @@index([ownerId]) // 加速"我的收录"查询
  @@index([contributedBy]) // 加速"我贡献到团队的副本"查询
  @@index([teamId]) // 加速团队空间内查询
  @@index([visibility]) // 加速公开广场筛选
  @@index([updatedAt]) // 加速"最近"排序
  @@index([folderId]) // 加速"文件夹内资源"查询
  @@schema("prompt")
}

// 提示词版本快照，线性版本历史，每次编辑前存一份快照
model PromptRecordVersion {
  // ① 主键
  id String @id @default(cuid()) // 版本快照主键

  // ② 业务字段
  name          String // 该版本的名称快照
  content       String  @db.Text // 该版本的内容快照
  versionNumber Int     @map("version_number") // 版本序号，递增
  message       String? // 版本说明，类似 commit message

  // ③ 时间戳
  createdAt DateTime @default(now()) @map("created_at") // 创建时间

  // ④ 外键列
  recordId String @map("record_id") // 所属收录记录 ID
  editorId String @map("editor_id") // 编辑人 ID

  // ⑤ 关联关系
  record PromptRecord @relation(fields: [recordId], references: [id], onDelete: Cascade) // 归属的收录记录（收录删除→级联删除所有版本）
  editor User         @relation("VersionEditor", fields: [editorId], references: [id], onDelete: Cascade) // 编辑人（用户删除→级联删除其创建的版本）

  // ⑥ 索引
  @@index([recordId]) // 加速"查询某收录的全部版本历史"
  @@schema("prompt")
}

// 提示词草稿，轻量暂存，无版本/无团队联动
model PromptDraft {
  // ① 主键
  id String @id @default(cuid())

  // ② 业务字段
  name    String
  content String   @db.Text
  images  String[] @default([])

  // ③ 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ④ 外键列
  ownerId  String  @map("owner_id")
  folderId String? @map("folder_id") // 所属文件夹 ID，null=未分类

  // ⑤ 关联关系
  owner  User    @relation("PromptDraftOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  folder Folder? @relation("FolderItems_PromptDraft", fields: [folderId], references: [id], onDelete: SetNull) // 所属文件夹（文件夹删除→资源保留，folderId 置空）

  // ⑥ 索引
  @@index([ownerId])
  @@index([folderId]) // 加速"文件夹内草稿"查询
  @@schema("prompt")
}

// 标签与收录的多对多关联
// ! 刻意用显式 m-n（不用隐式）：将来团队权限场景要在中间表上加 createdBy/teamId/role 等字段，隐式不支持
model PromptRecordTag {
  // ③ 时间戳
  createdAt DateTime @default(now()) @map("created_at")

  // ④ 外键列
  recordId String @map("record_id")
  tagId    String @map("tag_id")

  // ⑤ 关联关系
  record PromptRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  tag    Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  // ⑥ 索引
  @@id([recordId, tagId])
  @@index([tagId])
  @@schema("prompt")
}

// 用户收藏的提示词收录，驱动"收集"排序
model PromptFavorite {
  // ③ 时间戳
  createdAt DateTime @default(now()) @map("created_at")

  // ④ 外键列
  userId   String @map("user_id")
  recordId String @map("record_id")

  // ⑤ 关联关系
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  record PromptRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  // ⑥ 索引
  @@id([userId, recordId])
  @@index([userId]) // 加速"我的收藏"查询
  @@index([recordId])
  @@schema("prompt")
}

// 可见性枚举：private=仅自己/团队，public=公开广场
enum Visibility {
  private
  public

  @@schema("prompt")
}
