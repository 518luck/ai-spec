// # 提示词域：收录主表（含版本/标签/收藏）+ 草稿暂存 + 可见性控制
//
// 收录(PromptRecord) 是正式归档的内容，带版本历史、标签、收藏与团队/公开可见性；
// 草稿(PromptDraft) 是轻量暂存，无版本、无团队联动，仅归属个人。
// ! 收录与团队为强绑定：团队删除→级联删除其空间内的收录；用户删除→级联删除其收录

// 收录主表：承载完整内容、版本、标签与共享
model PromptRecord {
  // ① 主键
  id String @id @default(cuid()) // 收录主键

  // ② 业务字段
  name             String // 名称
  description      String? // 描述（可选）
  content          String     @db.Text // 提示词正文
  images           String[]   @default([]) // 图片 URL 列表，预留扩展
  visibility       Visibility @default(private) // 可见性：private=私有，public=公开广场
  team_id          String? // 所属团队 ID，null=个人空间，非 null=团队空间（仅标识归属）
  source_record_id String? // > fork 来源记录 ID，故意不建外键，允许源记录删除后悬空（保留 fork 血缘标记）
  use_count        Int        @default(0) // 使用次数，驱动"常用"排序
  view_count       Int        @default(0) // 浏览次数

  // ③ 时间戳
  created_at DateTime @default(now()) // 创建时间
  updated_at DateTime @updatedAt // 更新时间，驱动"最近"排序

  // ④ 外键列
  owner_id       String // 创建者 ID
  last_editor_id String? // 最近编辑人 ID（团队协作场景）
  folder_id      String? // 所属文件夹 ID，null=未分类

  // ⑤ 关联关系
  owner        User                  @relation("PromptRecordOwner", fields: [owner_id], references: [id], onDelete: Cascade) // 创建者（删除用户→级联删除收录）
  last_editor  User?                 @relation("PromptRecordEditor", fields: [last_editor_id], references: [id], onDelete: SetNull) // 最近编辑人（用户注销→仅清空记录）
  folder       Folder?               @relation("FolderItems_PromptRecord", fields: [folder_id], references: [id], onDelete: SetNull) // 所属文件夹（文件夹删除→资源保留，folder_id 置空）
  team         Team?                 @relation("TeamPromptRecords", fields: [team_id], references: [id], onDelete: Cascade) // 所属团队（团队删除→级联删除其空间内的收录；null=个人空间）
  versions     PromptRecordVersion[] // 版本历史
  tags         PromptRecordTag[] // 标签关联
  favorited_by PromptFavorite[] // 收藏记录

  // ⑥ 索引
  @@index([owner_id]) // 加速"我的收录"查询
  @@index([team_id]) // 加速团队空间内查询
  @@index([visibility]) // 加速公开广场筛选
  @@index([updated_at]) // 加速"最近"排序
  @@index([folder_id]) // 加速"文件夹内资源"查询
  @@schema("prompt")
}

// 提示词版本快照，线性版本历史，每次编辑前存一份快照
model PromptRecordVersion {
  // ① 主键
  id String @id @default(cuid()) // 版本快照主键

  // ② 业务字段
  name           String // 该版本的名称快照
  content        String  @db.Text // 该版本的内容快照
  version_number Int // 版本序号，递增
  message        String? // 版本说明，类似 commit message

  // ③ 时间戳
  created_at DateTime @default(now()) // 创建时间

  // ④ 外键列
  record_id String // 所属收录记录 ID
  editor_id String // 编辑人 ID

  // ⑤ 关联关系
  record PromptRecord @relation(fields: [record_id], references: [id], onDelete: Cascade) // 归属的收录记录（收录删除→级联删除所有版本）
  editor User         @relation("VersionEditor", fields: [editor_id], references: [id], onDelete: Cascade) // 编辑人（用户删除→级联删除其创建的版本）

  // ⑥ 索引
  @@index([record_id]) // 加速"查询某收录的全部版本历史"
  @@schema("prompt")
}

// 提示词草稿，轻量暂存，无版本/无团队联动
model PromptDraft {
  // ① 主键
  id String @id @default(cuid())

  // ② 业务字段
  name        String?
  content     String   @db.Text
  images      String[] @default([])

  // ③ 时间戳
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // ④ 外键列
  owner_id  String
  folder_id String? // 所属文件夹 ID，null=未分类

  // ⑤ 关联关系
  owner  User    @relation("PromptDraftOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  folder Folder? @relation("FolderItems_PromptDraft", fields: [folder_id], references: [id], onDelete: SetNull) // 所属文件夹（文件夹删除→资源保留，folder_id 置空）

  // ⑥ 索引
  @@index([owner_id])
  @@index([folder_id]) // 加速"文件夹内草稿"查询
  @@schema("prompt")
}

// 标签与收录的多对多关联
model PromptRecordTag {
  // ③ 时间戳
  created_at DateTime @default(now())

  // ④ 外键列
  record_id String
  tag_id    String

  // ⑤ 关联关系
  record PromptRecord @relation(fields: [record_id], references: [id], onDelete: Cascade)
  tag    Tag          @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  // ⑥ 索引
  @@id([record_id, tag_id])
  @@index([tag_id])
  @@schema("prompt")
}

// 用户收藏的提示词收录，驱动"收集"排序
model PromptFavorite {
  // ③ 时间戳
  created_at DateTime @default(now())

  // ④ 外键列
  user_id   String
  record_id String

  // ⑤ 关联关系
  user   User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  record PromptRecord @relation(fields: [record_id], references: [id], onDelete: Cascade)

  // ⑥ 索引
  @@id([user_id, record_id])
  @@index([record_id])
  @@schema("prompt")
}

// 可见性枚举：private=仅自己/团队，public=公开广场
enum Visibility {
  private
  public

  @@schema("prompt")
}
