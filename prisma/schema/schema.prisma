// 这是你的 Prisma 模式文件（Schema file），
// 在文档中了解更多信息：https://pris.ly/d/prisma-schema

// 只需几秒即可获取一个免费的托管版 Postgres 数据库：执行 npx create-db

generator client {
  provider = "prisma-client"
  output   = "../../src/shared/db/generator"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "token", "prompt", "shared"]
}

// 用户本人信息
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? // ? :可为空   (系统以后长期判断你这个邮箱是否已验证的标记)
  image         String?

  // 密码和安全字段
  passwordHash         String?
  invalidLoginAttempts Int       @default(0) // invalid 无效的  attempts 次数( 输错次数,成功后就清零)
  lockedAt             DateTime? // locked 锁定的 ( 这个账号是在什么时候被锁定的)

  accounts Account[]
  sessions Session[]
  tokens   Token[]

  // 提示词反向关系
  promptRecords        PromptRecord[]         @relation("PromptRecordOwner")
  promptRecordEdited   PromptRecord[]         @relation("PromptRecordEditor")
  promptRecordVersions PromptRecordVersion[]  @relation("VersionEditor")
  promptDrafts         PromptDraft[]          @relation("PromptDraftOwner")
  promptFavorites      PromptFavorite[]

  @@schema("auth")
}

// 第三方登陆账户
model Account {
  id                       String  @id @default(cuid())
  userId                   String // 关联到哪个用户
  type                     String // 账户类型，例如 OAuth 登陆的大类 oauth  email
  provider                 String // 登录提供商，例如 Google、GitHub
  providerAccountId        String // 该提供商中的账户 ID
  refresh_token            String? @db.Text // 刷新 access token 用的令牌 是“专门用来续期的”
  refresh_token_expires_in Int? // refresh token 的剩余有效期/过期时长   
  access_token             String? @db.Text // 当前 access token   是“直接拿来用的”
  expires_at               Int? // access token 过期时间（通常是时间戳）
  token_type               String? // token 类型，例如 Bearer
  scope                    String? // 授权范围
  id_token                 String? @db.Text // OpenID Connect 返回的 ID token  用来说明“登录的这个人是谁”
  session_state            String? // 某些提供商返回的会话状态标记

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId]) // 联合唯一索引
  @@schema("auth")
}

// 会话
model Session {
  id           String   @id @default(cuid()) // 这条 session 记录自己的主键
  sessionToken String   @unique // 会话 token，前端通常携带它来标识当前登录会话
  userId       String // 这条 session 属于哪个用户
  expires      DateTime // 这条会话什么时候过期
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("auth")
}
