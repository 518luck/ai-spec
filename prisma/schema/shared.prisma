// # 共享域：跨域通用字典，存放被多个业务领域引用的通用资源

// 全局标签定义，可被任意领域的实体通过各自的关联表引用
model Tag {
  // ① 主键
  id String @id @default(cuid())

  // ② 业务字段
  name String @unique

  // ③ 时间戳
  createdAt DateTime @default(now()) @map("created_at")

  // ⑤ 关联关系（反向）
  promptRecordTags PromptRecordTag[]

  // ⑥ 索引
  @@schema("shared")
}
